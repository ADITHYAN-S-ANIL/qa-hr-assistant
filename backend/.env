# QA Chat – Environment Variables

# Flask secret
SECRET_KEY=qachat-dev-secret-key-2024

# PostgreSQL connection (individual params — safe for passwords with special chars)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=qachat
DB_USER=postgres
DB_PASS=adithyan@1

# Groq AI — PRIMARY (free, 14,400 req/day, no credit card) → console.groq.com
GROQ_API_KEY=

# Google Gemini AI — FALLBACK (free, 1,500 req/day)
GEMINI_API_KEY=AIzaSyAwYn7TxN3Wy52SfPhqG_qWuWMlk0mOiXo

# GitHub OAuth (optional)
# Set Authorization callback URL to: http://localhost:5000/api/auth/github/callback
