# ───────────────────────────────────
#  QA Chat – Environment Variables
#  Copy this to .env and fill in values
# ───────────────────────────────────

# Flask
SECRET_KEY=your-super-secret-jwt-key-change-this

# PostgreSQL (must have pgvector extension installed)
# Install pgvector: https://github.com/pgvector/pgvector#installation
DB_HOST=localhost
DB_PORT=5432
DB_NAME=qachat
DB_USER=postgres
DB_PASS=postgres

# Google Gemini AI (free tier at https://aistudio.google.com/app/apikey)
# Used for both chat completions AND RAG embeddings (text-embedding-004)
GEMINI_API_KEY=your-gemini-api-key-here

# Groq AI (optional, free at https://console.groq.com)
# Faster alternative for chat (14,400 req/day free)
GROQ_API_KEY=your-groq-api-key-here

# GitHub OAuth  (create at https://github.com/settings/developers)
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# Frontend URL (for OAuth redirects)
FRONTEND_URL=http://localhost:5173

# Optional – password salt (change in production!)
PASSWORD_SALT=qa-chat-salt-change-me

# Token expiry in hours
TOKEN_EXPIRY_HOURS=24
